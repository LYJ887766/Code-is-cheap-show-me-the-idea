<Window x:Class="SnakeGame.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Snake Game" Height="700" Width="900" ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部状态栏 -->
        <DockPanel Grid.Row="0" Background="#2196F3" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0">
                <TextBlock Text="Score: " Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Score}" Foreground="White" FontSize="18" FontWeight="Bold" MinWidth="60" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0">
                <TextBlock Text="High Score: " Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding HighScore}" Foreground="White" FontSize="18" FontWeight="Bold" MinWidth="60" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0">
                <TextBlock Text="Level: " Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Level}" Foreground="White" FontSize="18" FontWeight="Bold" MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Right" Text="ARROWS/WASD to move, SPACE to pause"
                       Foreground="White" FontSize="14" TextAlignment="Right" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
        </DockPanel>

        <!-- 游戏画布 -->
        <Grid Grid.Row="1" Margin="20" Background="White" MinWidth="500" MinHeight="500">
            <Canvas x:Name="GameCanvas" Background="White"
                    Width="500" Height="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- 底部控制栏 -->
        <DockPanel Grid.Row="2" Background="#F5F5F5" Margin="20" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="{Binding PauseButtonText}"
                    Width="100" Height="40" FontSize="14" FontWeight="Bold"
                    Background="#4CAF50" Foreground="White" Click="PauseButton_Click"
                    Cursor="Hand" VerticalContentAlignment="Center"/>

            <Button DockPanel.Dock="Left" Content="Restart"
                    Width="100" Height="40" FontSize="14" FontWeight="Bold"
                    Background="#FF9800" Foreground="White" Click="RestartButton_Click"
                    Margin="10,0,0,0" Cursor="Hand" VerticalContentAlignment="Center"/>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Difficulty" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="DifficultyCombo" Width="145" Height="35" FontSize="14"
                          SelectionChanged="DifficultyCombo_SelectionChanged"
                          IsEnabled="{Binding IsDifficultyEnabled}" Padding="5" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Easy (200ms)"/>
                    <ComboBoxItem Content="Standard (100ms)" IsSelected="True"/>
                    <ComboBoxItem Content="Hard (50ms)"/>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="{Binding StatusText}"
                       FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="{Binding StatusForeground}" FontWeight="Bold" DockPanel.Dock="Right" Margin="0,0,20,0"/>
        </DockPanel>
    </Grid>
</Window>
